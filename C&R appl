import tkinter as tk
from tkinter import messagebox
import calendar
from datetime import datetime

# Store reminders
reminders = {}

# Function to show calendar
def show_calendar():
    year = int(year_entry.get())
    month = int(month_entry.get())

    cal = calendar.month(year, month)
    calendar_text.delete(1.0, tk.END)
    calendar_text.insert(tk.END, cal)

# Function to add reminder
def add_reminder():
    date = date_entry.get()
    text = reminder_entry.get()

    if date == "" or text == "":
        messagebox.showwarning("Input Error", "Please enter date and reminder")
        return

    if date in reminders:
        reminders[date].append(text)
    else:
        reminders[date] = [text]

    messagebox.showinfo("Success", "Reminder Added!")
    reminder_entry.delete(0, tk.END)

# Function to view reminders
def view_reminders():
    reminder_text.delete(1.0, tk.END)
    if not reminders:
        reminder_text.insert(tk.END, "No reminders found.")
        return

    for date, texts in reminders.items():
        reminder_text.insert(tk.END, f"{date}:\n")
        for t in texts:
            reminder_text.insert(tk.END, f"  - {t}\n")

# GUI Setup
root = tk.Tk()
root.title("Calendar & Reminder App")
root.geometry("500x600")

# Calendar Section
tk.Label(root, text="Year").pack()
year_entry = tk.Entry(root)
year_entry.pack()
year_entry.insert(0, datetime.now().year)

tk.Label(root, text="Month").pack()
month_entry = tk.Entry(root)
month_entry.pack()
month_entry.insert(0, datetime.now().month)

tk.Button(root, text="Show Calendar", command=show_calendar).pack()

calendar_text = tk.Text(root, height=8)
calendar_text.pack()

# Reminder Section
tk.Label(root, text="Enter Date (YYYY-MM-DD)").pack()
date_entry = tk.Entry(root)
date_entry.pack()

tk.Label(root, text="Enter Reminder").pack()
reminder_entry = tk.Entry(root)
reminder_entry.pack()

tk.Button(root, text="Add Reminder", command=add_reminder).pack()
tk.Button(root, text="View Reminders", command=view_reminders).pack()

reminder_text = tk.Text(root, height=10)
reminder_text.pack()

# Run App
root.mainloop()
